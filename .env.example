# ─────────────────────────────────────────────────────────────
# Hookline — example environment variables (root)
# Copy to .env and fill in. NEVER commit the real .env.
# Per-package runtime config lives alongside each package:
#   - Worker local secrets:   packages/api/.dev.vars  (see .dev.vars.example there)
#   - Worker bindings/config: packages/api/wrangler.toml (not secrets)
# ─────────────────────────────────────────────────────────────

# Cloudflare account (used by Wrangler CLI for deploys)
# Find the account ID in the Cloudflare dashboard URL or `wrangler whoami`.
CLOUDFLARE_ACCOUNT_ID=your-account-id-here

# Optional: a scoped API token for CI deploys (GitHub Actions).
# Create at dash.cloudflare.com > My Profile > API Tokens, scoped to
# Workers Scripts:Edit + D1:Edit. Local dev uses `wrangler login` instead.
CLOUDFLARE_API_TOKEN=your-deploy-token-here
