# packages/dashboard/.dev.vars — LOCAL dashboard vars for `next dev` (via
# @opennextjs/cloudflare). Copy to `.dev.vars` (gitignored).
#
# Selects which Next.js .env files load locally. Bindings (DB) come from
# wrangler.jsonc, not here. There is no signing secret here — the dashboard
# never reads it.
NEXTJS_ENV=development

# HTTP Basic Auth credential gating the dashboard (see middleware.ts). Format is
# `user:password` — the whole string is compared. In production this is set with
# `wrangler secret put DASHBOARD_BASIC_AUTH` on the hookline-dashboard Worker;
# locally it loads from .dev.vars. Use ASCII; pick a long, random password.
DASHBOARD_BASIC_AUTH=admin:local-dev-change-me

# Optional public-demo opt-out. When set to "true", the Basic Auth gate is
# skipped and the dashboard is publicly readable with no login — used for the
# portfolio demo deployment (seeded data only, no secrets exposed). Leave unset
# for any real deployment so the auth gate stays on (fail-closed default).
# DASHBOARD_PUBLIC=true
